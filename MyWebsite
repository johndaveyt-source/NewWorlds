            story: {
                title: "Story Circles",
                content: `
                    <div class="space-y-6">
                        <div class="bg-sage/10 rounded-2xl p-6 border-l-4 border-sage">
                            <h4 class="font-bold text-charcoal mb-2">Learning Objective</h4>
                            <p class="text-charcoal/70">Experience traditional oral transmission of knowledge through structured listening and sharing protocols that honor the story as teacher.</p>
                        </div>
                        
                        <div class="grid md:grid-cols-2 gap-6">
                            <div>
                                <h4 class="font-bold text-charcoal mb-3 flex items-center">
                                    <i data-lucide="clock" class="w-5 h-5 mr-2 text-sage"></i>
                                    Duration
