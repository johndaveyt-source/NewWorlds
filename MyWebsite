            const email = e.target.querySelector('input[type="email"]').value;
            alert(`Thank you for subscribing with ${email}!\n\nYou'll receive our monthly facilitation newsletter with new indigenous knowledge activities and community highlights.`);
            e.target.reset();
        }

        // Close modal on escape key
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') {
                closeActivity();
            }
        });
